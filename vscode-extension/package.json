{
	"name": "obsicapture",
	"displayName": "ObsiCapture",
	"description": "Generate project documentation with Claude AI and save directly to Obsidian",
	"version": "0.1.5",
	"publisher": "ktmihs",
	"icon": "images/marketplace-icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/ktmihs/Obsicapture.git"
	},
	"bugs": {
		"url": "https://github.com/ktmihs/Obsicapture/issues"
	},
	"homepage": "https://github.com/ktmihs/Obsicapture#readme",
	"keywords": [
		"obsidian",
		"claude",
		"ai",
		"documentation",
		"markdown",
		"note-taking"
	],
	"galleryBanner": {
		"color": "#4B2D8A",
		"theme": "dark"
	},
	"license": "MIT",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Other",
		"Machine Learning"
	],
	"activationEvents": [],
	"main": "./dist/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "obsicapture-sidebar",
					"title": "ObsiCapture",
					"icon": "images/icon.svg"
				}
			]
		},
		"views": {
			"obsicapture-sidebar": [
				{
					"id": "obsicapture.sidebarView",
					"name": "문서 생성",
					"type": "webview"
				}
			]
		},
		"commands": [
			{
				"command": "obsicapture.openPanel",
				"title": "ObsiCapture: 패널로 열기",
				"icon": "$(notebook)"
			}
		],
		"configuration": {
			"title": "ObsiCapture",
			"properties": {
				"obsicapture.claudeApiKey": {
					"type": "string",
					"default": "",
					"description": "Anthropic Claude API 키"
				},
				"obsicapture.vaultPath": {
					"type": "string",
					"default": "",
					"description": "Obsidian Vault 절대 경로 (예: C:/Users/.../MyVault)"
				},
				"obsicapture.defaultFolder": {
					"type": "string",
					"default": "",
					"description": "기본 저장 폴더 (Vault 내 하위 폴더, 비워두면 루트)"
				},
				"obsicapture.maxFiles": {
					"type": "number",
					"default": 50,
					"description": "한 번에 읽을 최대 파일 수"
				},
				"obsicapture.model": {
					"type": "string",
					"default": "claude-sonnet-4-6",
					"enum": [
						"claude-sonnet-4-6",
						"claude-opus-4-7",
						"claude-haiku-4-5-20251001"
					],
					"description": "사용할 Claude 모델"
				}
			}
		}
	},
	"scripts": {
		"build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --sourcemap",
		"watch": "npm run build -- --watch",
		"package": "npm run build && vsce package",
		"publish": "npm run build && vsce publish"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.85.0",
		"esbuild": "^0.20.0",
		"typescript": "^5.3.0"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.32.0"
	}
}
