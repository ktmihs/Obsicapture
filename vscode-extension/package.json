{
	"name": "obsicapture",
	"displayName": "ObsiCapture",
	"description": "프로젝트 코드 기반 문서를 Claude AI로 생성하고 Obsidian에 저장",
	"version": "0.1.3",
	"publisher": "obsicapture",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "obsicapture.openPanel",
				"title": "ObsiCapture: 문서 생성",
				"icon": "$(notebook)"
			}
		],
		"configuration": {
			"title": "ObsiCapture",
			"properties": {
				"obsicapture.claudeApiKey": {
					"type": "string",
					"default": "",
					"description": "Anthropic Claude API 키"
				},
				"obsicapture.vaultPath": {
					"type": "string",
					"default": "",
					"description": "Obsidian Vault 절대 경로 (예: C:/Users/.../MyVault)"
				},
				"obsicapture.defaultFolder": {
					"type": "string",
					"default": "",
					"description": "기본 저장 폴더 (Vault 내 하위 폴더, 비워두면 루트)"
				},
				"obsicapture.maxFiles": {
					"type": "number",
					"default": 50,
					"description": "한 번에 읽을 최대 파일 수"
				},
				"obsicapture.model": {
					"type": "string",
					"default": "claude-sonnet-4-6",
					"enum": [
						"claude-sonnet-4-6",
						"claude-opus-4-7",
						"claude-haiku-4-5-20251001"
					],
					"description": "사용할 Claude 모델"
				}
			}
		}
	},
	"scripts": {
		"build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --sourcemap",
		"watch": "npm run build -- --watch",
		"package": "npm run build && vsce package"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.85.0",
		"esbuild": "^0.20.0",
		"typescript": "^5.3.0"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.32.0"
	}
}
